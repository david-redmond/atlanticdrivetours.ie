# Resend (contact / enquiry emails)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# Google Analytics 4 — measurement ID (e.g. G-XXXXXXXXXX). Loaded only after cookie consent.
# Prefer GA_MEASUREMENT_ID for Docker Compose / runtime (no rebuild). NEXT_PUBLIC_GA_ID still works for `next dev` / build-time injection.
GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_ID=
